{
  "name": "kimi-plugin-cc",
  "version": "0.4.0",
  "description": "Claude Code plugin for Kimi delegation — code review, exploration, and task execution",
  "type": "module",
  "scripts": {
    "test": "node --test --test-concurrency=1 tests/**/*.test.mjs",
    "smoke": "bash tests/smoke.sh",
    "lint": "node scripts/lint.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run --skip-git-check",
    "build": "echo 'No build step required'"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "files": [
    "plugins/",
    ".claude-plugin/",
    "docs/",
    ".env.example",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luanmorenommaciel/kimi-plugin-cc.git"
  }
}
