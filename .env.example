# Kimi Plugin CC — Environment Variables
# Copy this file to .env and fill in your actual keys.
# Never commit .env to git.

# Tavily — for web research, docs lookup, and API validation
# Get a key at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Firecrawl — for structured doc extraction and change monitoring
# Get a key at: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-key-here

# Exa — for semantic code pattern search
# Get a key at: https://exa.ai
EXA_API_KEY=exa-your-key-here

# Codex — for adversarial plan/diff review (optional)
# Auto-detects if not set; set to override
# CODEX_CMD=codex

# Kimi cost rates (optional overrides)
# KIMI_COST_PER_1M_INPUT=0.5
# KIMI_COST_PER_1M_OUTPUT=2.0
# KIMI_COST_PER_1M_CACHED=0.1
